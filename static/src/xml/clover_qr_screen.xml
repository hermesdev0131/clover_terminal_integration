<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="clover_terminal_integration.CloverQRScreen">
        <Dialog title="'Clover QR Payment'" size="'md'" contentClass="'clover-qr-screen p-0'">

            <t t-set-slot="body">
                <div class="text-center p-4">

                    <!-- Order reference + amount -->
                    <p class="text-muted small mb-1">
                        Order <strong t-esc="props.orderRef"/>
                    </p>
                    <h3 class="fw-bold mb-4" t-esc="amountFormatted"/>

                    <!-- QR code image -->
                    <div class="d-flex justify-content-center mb-4">
                        <!-- URL / data-URI → display as image -->
                        <img t-if="props.qrPayload and isQrUrl"
                             t-att-src="props.qrPayload"
                             alt="QR Code"
                             class="border rounded p-2 bg-white"
                             style="width:260px;height:260px;object-fit:contain;"/>
                        <!-- Raw code string → show it (fallback) -->
                        <div t-elif="props.qrPayload"
                             class="border rounded p-3 bg-white d-flex align-items-center justify-content-center"
                             style="width:260px;height:260px;word-break:break-all;font-size:0.7rem;">
                            <span class="text-muted" t-esc="props.qrPayload"/>
                        </div>
                        <!-- No QR payload yet -->
                        <div t-else=""
                             class="border rounded bg-light d-flex align-items-center justify-content-center"
                             style="width:260px;height:260px;">
                            <div class="text-muted">
                                <i class="fa fa-spinner fa-spin fa-2x d-block mb-2"/>
                                Loading QR...
                            </div>
                        </div>
                    </div>

                    <!-- Status badge -->
                    <div class="mb-2">
                        <span t-if="state.status === 'pending' or state.status === 'created' or state.status === 'waiting'"
                              class="badge bg-warning text-dark px-3 py-2 fs-6">
                            <i class="fa fa-spinner fa-spin me-2"/>
                            <t t-esc="state.label"/>
                        </span>
                        <span t-elif="isApproved"
                              class="badge bg-success px-3 py-2 fs-6">
                            <i class="fa fa-check-circle me-2"/>
                            <t t-esc="state.label"/>
                        </span>
                        <span t-else=""
                              class="badge bg-danger px-3 py-2 fs-6">
                            <i class="fa fa-times-circle me-2"/>
                            <t t-esc="state.label"/>
                        </span>
                    </div>

                    <p t-if="!isDone" class="text-muted small mt-2 mb-0">
                        Scan the QR with your payment app
                    </p>

                </div>
            </t>

            <t t-set-slot="footer">
                <button t-if="!isDone"
                        class="btn btn-secondary"
                        t-on-click="cancel">
                    Cancel
                </button>
            </t>

        </Dialog>
    </t>

</templates>
