<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="clover_terminal_integration.CloverQRScreen">
        <Dialog title="'Clover QR Payment'" size="'md'" contentClass="'clover-qr-screen p-0'">

            <t t-set-slot="body">
                <div class="text-center p-4">

                    <!-- Order reference + amount -->
                    <p class="text-muted small mb-1">
                        Order <strong t-esc="props.orderRef"/>
                    </p>
                    <h3 class="fw-bold mb-4">$ <t t-esc="amountFormatted"/></h3>

                    <!-- QR code display -->
                    <div class="d-flex justify-content-center mb-4">
                        <!-- URL / data-URI → display as image -->
                        <img t-if="hasQrPayload and isQrUrl"
                             t-att-src="state.qrPayload"
                             alt="QR Code"
                             class="border rounded p-2 bg-white"
                             style="width:260px;height:260px;object-fit:contain;"/>
                        <!-- Raw code string → show it -->
                        <div t-elif="hasQrPayload"
                             class="border rounded p-3 bg-white d-flex align-items-center justify-content-center"
                             style="width:260px;height:260px;word-break:break-all;font-size:0.7rem;">
                            <span class="text-muted" t-esc="state.qrPayload"/>
                        </div>
                        <!-- No QR payload — show scan-on-terminal message -->
                        <div t-else=""
                             class="border rounded bg-light d-flex align-items-center justify-content-center flex-column"
                             style="width:260px;height:260px;">
                            <i class="fa fa-qrcode fa-4x text-muted mb-3"/>
                            <p class="text-muted fw-bold mb-1">Scan QR on terminal</p>
                            <p class="text-muted small mb-0">The QR code is displayed on the Clover device</p>
                        </div>
                    </div>

                    <!-- Status -->
                    <div class="mb-2">
                        <span class="badge bg-warning text-dark px-3 py-2 fs-6">
                            <i class="fa fa-spinner fa-spin me-2"/>
                            Waiting for payment...
                        </span>
                    </div>

                </div>
            </t>

            <t t-set-slot="footer">
                <button class="btn btn-secondary"
                        t-on-click="cancel">
                    Cancel
                </button>
            </t>

        </Dialog>
    </t>

</templates>
