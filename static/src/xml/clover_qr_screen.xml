<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="clover_terminal_integration.CloverQRScreen">
        <Dialog title="'Clover QR Payment'" size="'md'">

            <!-- Body content as default slot -->
            <div class="text-center p-4">

                <!-- Order reference + amount -->
                <p class="text-muted small mb-1">
                    Order <strong t-esc="props.orderRef"/>
                </p>
                <h3 class="fw-bold mb-4">$ <t t-esc="amountFormatted"/></h3>

                <!-- QR code display -->
                <div class="d-flex justify-content-center mb-4">
                    <!-- QR code rendered dynamically -->
                    <div t-if="hasQrPayload"
                         t-ref="qrContainer"
                         class="d-flex align-items-center justify-content-center"
                         style="width:260px;height:260px;">
                        <i class="fa fa-spinner fa-spin fa-2x text-muted"/>
                    </div>
                    <!-- No QR payload — show scan-on-terminal message -->
                    <div t-else=""
                         class="border rounded d-flex align-items-center justify-content-center flex-column"
                         style="width:260px;height:260px;background-color:#f8f9fa;">
                        <i class="fa fa-qrcode fa-4x mb-3" style="color:#495057;"/>
                        <p class="fw-bold mb-1" style="color:#212529;">Scan QR on terminal</p>
                        <p class="small mb-0" style="color:#6c757d;">The QR code is displayed on the Clover device</p>
                    </div>
                </div>

                <!-- Status -->
                <div class="mb-2">
                    <span class="badge bg-warning text-dark px-3 py-2 fs-6">
                        <i class="fa fa-spinner fa-spin me-2"/>
                        Waiting for payment...
                    </span>
                </div>

            </div>

            <t t-set-slot="footer">
                <button class="btn btn-secondary"
                        t-on-click="cancel">
                    Cancel
                </button>
            </t>

        </Dialog>
    </t>

</templates>
